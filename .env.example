# PayFast Configuration Example
# Copy this file to .env.local or .env.development for local testing
# The app will automatically use .env.development for development and .env.production for production builds

REACT_APP_PAYFAST_URL=https://sandbox.payfast.co.za/eng/process
REACT_APP_PAYFAST_MERCHANT_ID=YOUR_MERCHANT_ID
REACT_APP_PAYFAST_MERCHANT_KEY=YOUR_MERCHANT_KEY
REACT_APP_PAYFAST_PASSPHRASE=YOUR_PASSPHRASE
REACT_APP_PAYFAST_RETURN_URL=http://localhost:3000/payment/success
REACT_APP_PAYFAST_CANCEL_URL=http://localhost:3000/payment/cancel
REACT_APP_NOTIFY_URL=https://your-supabase-project.supabase.co/functions/v1/payfast-notify
