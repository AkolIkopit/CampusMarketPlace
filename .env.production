# PayFast Production Configuration
# Replace these values with your production PayFast credentials
REACT_APP_PAYFAST_URL=https://www.payfast.co.za/eng/process
REACT_APP_PAYFAST_MERCHANT_ID=YOUR_PRODUCTION_MERCHANT_ID
REACT_APP_PAYFAST_MERCHANT_KEY=YOUR_PRODUCTION_MERCHANT_KEY
REACT_APP_PAYFAST_PASSPHRASE=YOUR_PRODUCTION_PASSPHRASE
REACT_APP_PAYFAST_RETURN_URL=https://yourproductiondomain.com/payment/success
REACT_APP_PAYFAST_CANCEL_URL=https://yourproductiondomain.com/payment/cancel
REACT_APP_NOTIFY_URL=https://yourproductiondomain.com/functions/v1/payfast-notify
